# MikroTik MCP Server - Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# Path to device inventory JSON file
MIKROTIK_DEVICES_FILE=devices.json

# Default request timeout in seconds
MIKROTIK_TIMEOUT=60

# Lab mode: bypass ITSM gate for config changes (set to "true" for testing)
NETCLAW_LAB_MODE=false

# ServiceNow Change Request validation (for production config changes)
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_API_KEY=your-service-now-api-key